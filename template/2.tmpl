{{ define "2" }}
{{ template "header" . }}
<div class="container">
	<div class="page-header">
		<h1>Welcome</h1>
	</div>
	<p class="lead">Shortlisting</p>
	<form class="form-horizontal" action="index" method="get">
		<div class="col-xs-12 text-center lead">
			<a href="#">Matching Properties <span class="badge">1000</span></a>
		</div>
		<div class="form-group">
			<label class="col-xs-4 control-label">Purpose of Purchase</label>
			<div class="btn-group col-xs-8">
				<input type="radio" name="purpose" value="ownstay" checked> Own Stay<br>
				<input type="radio" name="purpose" value="investment"> Investment<br>
			</div>
		</div>
		<div class="form-group">
			<label class="col-xs-4 control-label">Tenure</label>
			<div class="col-xs-8">
				<select class="form-control" name="tenure" id="tenure">
					<option selected="selected" value=""></option>
					<option value="1">Freehold Group</option>
					<option value="2">Leasehold Group</option>
				</select>
			</div>
		</div>
		<div class="form-group">
			<div class="col-xs-offset-4 col-xs-8">
				<button type="submit" class="btn btn-default">Save</button>
			</div>
		</div>
	</form>
</div>
{{ template "footer" }}
{{ end }}
